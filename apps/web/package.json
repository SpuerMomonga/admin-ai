{
  "name": "@admin-ai/web",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "paraglide:compile": "node ./scripts/compile-paraglide.mjs",
    "preview": "vite preview",
    "prepare": "pnpm run paraglide:compile && svelte-kit sync || echo ''",
    "check": "pnpm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "pnpm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint ."
  },
  "dependencies": {
    "@admin-ai/contracts": "workspace:*",
    "@admin-ai/ui": "workspace:*",
    "@inlang/paraglide-js": "^2.15.0",
    "@lucide/svelte": "^0.577.0"
  },
  "devDependencies": {
    "@inlang/plugin-m-function-matcher": "^2.2.2",
    "@inlang/plugin-message-format": "^4.4.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
